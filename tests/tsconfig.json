{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "mocha", "chai", "selenium-webdriver"]
  },
  "include": ["specs/**/*.ts", "support/**/*.ts", "pages/**/*.ts"]
}
